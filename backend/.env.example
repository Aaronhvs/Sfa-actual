# App
APP_ENV=development
SECRET_KEY=change-me
APP_VERSION=0.1.0
DEBUG=True

# Database (app connection string)
DATABASE_URL=postgresql+asyncpg://sfa:change-me@db:5432/sfa

# PostgreSQL service credentials (used by docker-compose db service)
POSTGRES_USER=sfa
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sfa

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# External APIs
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Admin API key — empty in dev (auth disabled). Must be set in production.
ADMIN_API_KEY=

# CORS — comma-separated list of allowed origins
# Development: http://localhost:5173,http://localhost:3000
# Production:  https://tudominio.cl,https://www.tudominio.cl
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_VERSION=0.1.0
DEBUG=False
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-strong-secret-min-32-chars

# ─── Database (app connection) ───────────────────────────────────────────────
# Password must match POSTGRES_PASSWORD below
DATABASE_URL=postgresql+asyncpg://sfa:REPLACE_PASSWORD@db:5432/sfa

# ─── PostgreSQL service credentials ─────────────────────────────────────────
POSTGRES_USER=sfa
POSTGRES_PASSWORD=REPLACE_PASSWORD
POSTGRES_DB=sfa

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ─── External APIs ───────────────────────────────────────────────────────────
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ─── Admin API key ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Required — without this, all /admin and /scoring endpoints return 503
ADMIN_API_KEY=replace-with-strong-admin-key

# ─── CORS ────────────────────────────────────────────────────────────────────
# Vercel domain + any custom domain pointing to the frontend
CORS_ORIGINS=https://your-app.vercel.app,https://tudominio.cl

# ─── Traefik / HTTPS ─────────────────────────────────────────────────────────
# Subdomain for the API (must have an A record pointing to this VPS)
DOMAIN=api.tudominio.cl
# Email for Let's Encrypt SSL certificate notifications
ACME_EMAIL=tu@email.com
